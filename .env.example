# Clerk (https://dashboard.clerk.com o integración Vercel Marketplace)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Neon Postgres (integración Vercel Marketplace → Storage → Neon)
# Para migraciones, si Vercel te da ambas, usá UNPOOLED:
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
# DATABASE_URL_UNPOOLED=postgresql://user:password@host/db?sslmode=require

# Vercel Blob (Storage → Blob en el dashboard de Vercel)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
